{
  "name": "@strange-huge/icons",
  "version": "0.0.1",
  "description": "Animated SVG icon pack for the Strange Huge design system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "framer-motion": ">=10",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "framer-motion": "^11.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "icons",
    "animated",
    "svg",
    "react",
    "design-system",
    "strange-huge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/strange-rock/strange-huge-icons.git"
  }
}
